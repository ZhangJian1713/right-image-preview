{
  "name": "right-image-preview",
  "version": "0.1.0",
  "type": "module",
  "description": "A dependency-free React image preview component with Lightroom-style discrete zoom stops, multi-group navigation, flip/rotate, auto-fade controls, and full keyboard support.",
  "keywords": [
    "react",
    "image-preview",
    "lightbox",
    "zoom",
    "typescript",
    "image-viewer",
    "gallery",
    "photo-viewer",
    "no-dependencies"
  ],
  "license": "MIT",
  "author": "YOUR_NAME zhangjian1713@gmail.com",
  "homepage": "https://github.com/YOUR_GITHUB_USERNAME/right-image-preview#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_GITHUB_USERNAME/right-image-preview.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_GITHUB_USERNAME/right-image-preview/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
